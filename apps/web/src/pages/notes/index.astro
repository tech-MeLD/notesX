---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import NoteCard from "../../components/notes/NoteCard.astro";
import { sortNotes } from "../../lib/notes";

const notes = sortNotes(await getCollection("notes", ({ data }) => !data.draft));
---

<BaseLayout title="笔记 | Knowledge Observatory" description="浏览来自 Obsidian 的结构化笔记内容。">
  <section class="max-w-3xl">
    <p class="text-xs uppercase tracking-[0.22em] text-[var(--muted)]">Notes</p>
    <h1 class="mt-4 font-display text-5xl text-[var(--ink)]">保持 Obsidian 的组织方式，同时拥有网站级体验。</h1>
    <p class="mt-5 text-base leading-8 text-[var(--muted)]">
      这里所有内容都来自 Astro Content Collections，可直接由 Obsidian 同步脚本生成，并保留相对路径和标签。
    </p>
  </section>

  <section class="grid gap-2">
    {notes.map((entry) => <NoteCard entry={entry} />)}
  </section>
</BaseLayout>
