# Required for local build, Cloudflare deployment, and Supabase Auth on the frontend
PUBLIC_SITE_URL=https://knowledge.example.com
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side API origin used by the Astro/Cloudflare proxy route.
# Keep this as your backend origin, even if it is plain HTTP inside your own server/network.
API_ORIGIN=http://127.0.0.1:8000

# Optional: only set this when you already have a direct HTTPS API domain.
# If omitted, the frontend will use the same-origin /api/v1 proxy automatically.
# PUBLIC_API_BASE_URL=https://api.knowledge.example.com

# Local-only: needed when syncing Obsidian notes into Astro content
OBSIDIAN_VAULT_DIR=D:/path/to/your/obsidian/vault
