# Core runtime
APP_ENV=development
DATABASE_URL=postgresql://postgres.<project-ref>:your-password@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SITE_URL=http://127.0.0.1:4321
BACKEND_CORS_ORIGINS=http://127.0.0.1:4321,http://localhost:4321,https://knowledge.example.com
ADMIN_API_TOKEN=change-me
# Keep PUBLIC_SITE_URL and BACKEND_CORS_ORIGINS aligned with your frontend domain so GitHub OAuth and email magic-link redirects stay valid.

# Optional: keep AI disabled by leaving AI_API_KEY empty
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4.1-mini

# Optional auth override. Most cases can keep the defaults.
SUPABASE_JWT_AUDIENCE=authenticated
# SUPABASE_JWKS_URL=
# SUPABASE_JWT_ISSUER=

# Optional runtime tuning. Change only when you have a clear reason.
RSS_SCHEDULER_ENABLED=true
RSS_SCHEDULER_INTERVAL_MINUTES=15
RSS_FEED_TIMEOUT_SECONDS=20
RSS_CACHE_TTL_SECONDS=180
RSS_MAX_PARALLEL_FETCHES=6
RSS_MAX_PARALLEL_SUMMARIES=4
RSS_SUMMARY_MAX_CHARS=6000
RSS_SUMMARY_RECOVERY_BATCH_SIZE=24
RSS_SUMMARY_FAILED_RETRY_AFTER_MINUTES=60
RSS_SUMMARY_PROCESSING_TIMEOUT_MINUTES=20
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=8
